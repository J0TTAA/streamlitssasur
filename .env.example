# ─────────────────────────────────────────────────────────────────────────────
# Configuración de despliegue — copiar a .env y editar
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Base de datos PostgreSQL ──────────────────────────────────────────────────
# Cambiar la contraseña en producción
POSTGRES_USER=interconsultas
POSTGRES_PASSWORD=CambiaMeEnProduccion123!
POSTGRES_DB=interconsultas

# ── Exposición de puertos de desarrollo ───────────────────────────────────────
# En producción dejar en 127.0.0.1 (solo accesible localmente, nginx hace el proxy)
# Para desarrollo local cambiar a 0.0.0.0 si necesitas acceso directo
API_BIND=127.0.0.1
FRONTEND_BIND=127.0.0.1
